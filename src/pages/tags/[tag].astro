---
import BlogPost from "../../components/BlogPost.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

/**
 * This function generates the static paths for the tag pages.
 * Each object in the returned array represents a path that will be generated at build time.
 * The `params` object contains the dynamic segment of the URL, which in this case is the `tag` parameter.
 * The `params` property should match the dynamic segment defined in the file name (e.g., [tag].astro).
 *
 * Any value not set will result in a 404 page, so make sure to include all values needed.
 */
export async function getStaticPaths() {
  const allPosts = Object.values(
    import.meta.glob("../posts/*.md", { eager: true }),
  );

  const uniqueTags = new Set(
    allPosts.flatMap((post: any) => post.frontmatter.tags || []),
  );

  return Array.from(uniqueTags).map((tag) => ({
    params: { tag },
    props: {
      posts: allPosts.filter((post: any) =>
        post.frontmatter.tags?.includes(tag),
      ),
    },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<BaseLayout pageTitle={tag}>
  <p>Posts tagged with "{tag}"</p>
  <ul>
    {posts.map((post: any) => (
      <BlogPost url={post.url} title={post.frontmatter.title} />
    ))}
  </ul>
</BaseLayout>
